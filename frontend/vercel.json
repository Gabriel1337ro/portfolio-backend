{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/frontend",
  "framework": "angular",
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "status": 200
    }
  ]
} 